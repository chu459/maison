{
  "name": "AI电商客服工作流",
  "description": "针对电商场景优化的智能客服工作流，支持产品咨询、促销推荐、订单查询等功能",
  "version": "1.0.0",
  "nodes": [
    {
      "id": "start",
      "type": "start",
      "position": { "x": 100, "y": 100 },
      "data": {
        "label": "开始",
        "triggers": ["用户消息"]
      }
    },
    {
      "id": "intent_classifier",
      "type": "llm",
      "position": { "x": 300, "y": 100 },
      "data": {
        "label": "意图识别",
        "model": "gpt-3.5-turbo",
        "prompt": "请判断用户意图，从以下选项中选择：\n1. 产品咨询（询问商品信息、规格、价格）\n2. 促销活动（询问优惠、折扣、满减）\n3. 物流查询（询问发货时间、物流状态）\n4. 售后问题（退换货、维修）\n5. 其他\n\n用户输入：{{user_input}}",
        "output_mapping": {
          "intent": "response"
        }
      }
    },
    {
      "id": "knowledge_retrieval",
      "type": "knowledge",
      "position": { "x": 500, "y": 100 },
      "data": {
        "label": "知识库检索",
        "knowledge_base_id": "ecommerce_kb",
        "query": "{{user_input}}",
        "top_k": 3
      }
    },
    {
      "id": "response_generator",
      "type": "llm",
      "position": { "x": 700, "y": 100 },
      "data": {
        "label": "回答生成",
        "model": "gpt-3.5-turbo",
        "prompt": "你是一名专业的电商客服助手。请根据用户意图和知识库内容，给出专业、友好、促进转化的回答。\n\n用户意图：{{intent}}\n知识库内容：{{knowledge_content}}\n用户问题：{{user_input}}\n\n请生成回答：",
        "output_mapping": {
          "response": "response"
        }
      }
    },
    {
      "id": "end",
      "type": "end",
      "position": { "x": 900, "y": 100 },
      "data": {
        "label": "结束",
        "output": "{{response}}"
      }
    }
  ],
  "edges": [
    {
      "id": "e1",
      "source": "start",
      "target": "intent_classifier",
      "sourceHandle": "output",
      "targetHandle": "input"
    },
    {
      "id": "e2",
      "source": "intent_classifier",
      "target": "knowledge_retrieval",
      "sourceHandle": "output",
      "targetHandle": "input"
    },
    {
      "id": "e3",
      "source": "knowledge_retrieval",
      "target": "response_generator",
      "sourceHandle": "output",
      "targetHandle": "input"
    },
    {
      "id": "e4",
      "source": "response_generator",
      "target": "end",
      "sourceHandle": "output",
      "targetHandle": "input"
    }
  ],
  "variables": [
    {
      "name": "user_input",
      "type": "string",
      "default": ""
    },
    {
      "name": "intent",
      "type": "string",
      "default": ""
    },
    {
      "name": "knowledge_content",
      "type": "string",
      "default": ""
    },
    {
      "name": "response",
      "type": "string",
      "default": ""
    }
  ]
}